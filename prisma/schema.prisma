generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id             String         @id @default(cuid())
  title          String
  slug           String         @unique
  description    String
  location       String
  sector         String
  city           String         @default("Gurgaon")
  priceInr       Int
  type           String
  status         String
  bedrooms       Int?
  bathrooms      Int?
  areaSqft       Int
  featured       Boolean        @default(false)
  imageUrls      String
  amenities      String
  sourceType     String         @default("ADMIN")
  approvalStatus String         @default("APPROVED")
  boostTier      String         @default("STANDARD")
  leadRoutingMode String        @default("PLATFORM")
  featuredRequested Boolean     @default(false)
  listingContactName String?
  listingContactPhone String?
  listingContactRole String?
  vendorId       String?
  vendor         Dealer?        @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  leads          Lead[]

  @@index([location])
  @@index([type])
  @@index([priceInr])
  @@index([featured])
  @@index([approvalStatus])
  @@index([vendorId])
}

model Lead {
  id           String   @id @default(cuid())
  name         String
  phone        String
  requirement  String
  propertyId   String?
  assignedDealerId String?
  routingStatus String @default("PLATFORM")
  sourceChannel String @default("WEBSITE")
  property     Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([propertyId])
  @@index([createdAt])
}

model Dealer {
  id            String     @id @default(cuid())
  name          String
  companyName   String?
  email         String     @unique
  phone         String
  passwordHash  String
  role          String     @default("DEALER")
  status        String     @default("PENDING")
  planType      String     @default("BASIC")
  isVerified    Boolean    @default(false)
  featuredSlots Int        @default(0)
  leadBalance   Int        @default(0)
  analyticsSnapshot String @default("{}")
  serviceAreas  String     @default("[]")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  properties    Property[]

  @@index([status])
  @@index([role])
}
