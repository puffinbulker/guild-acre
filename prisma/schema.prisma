generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id             String         @id @default(cuid())
  title          String
  slug           String         @unique
  description    String
  location       String
  sector         String
  city           String         @default("Gurgaon")
  priceInr       Int
  type           String
  status         String
  bedrooms       Int?
  bathrooms      Int?
  areaSqft       Int
  featured       Boolean        @default(false)
  imageUrls      String
  amenities      String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  leads          Lead[]

  @@index([location])
  @@index([type])
  @@index([priceInr])
  @@index([featured])
}

model Lead {
  id           String   @id @default(cuid())
  name         String
  phone        String
  requirement  String
  propertyId   String?
  property     Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([propertyId])
  @@index([createdAt])
}
